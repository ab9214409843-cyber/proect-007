# Памятка: какие переменные нужны приложению.
# Скопируй этот файл в .env.local и подставь значения из Supabase
# (Dashboard → Project Settings → API). Файл .env.local в git НЕ коммитится.
# Эти же переменные нужно будет добавить в настройках Vercel при деплое.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
